{
  "name": "skillevel",
  "version": "0.1.0",
  "description": "A test runner for Claude Code skills — vitest for skills. Write YAML cases, run them through `claude -p`, and check that each skill triggers (and behaves) the way it should.",
  "type": "module",
  "bin": {
    "skillevel": "src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "files": [
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "skills",
    "eval",
    "test-runner",
    "llm",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5"
  }
}
